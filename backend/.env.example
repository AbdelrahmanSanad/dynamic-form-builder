# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/form_builder?schema=public

# ─── Auth ───────────────────────────────────────────────────────────────────
# Must be a long, random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
# Set to true when serving over HTTPS so the auth cookie is marked Secure.
COOKIE_SECURE=false

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins for the SPA.
CORS_ORIGIN=http://localhost:5173

# ─── File uploads ───────────────────────────────────────────────────────────
# Directory for locally stored uploads (relative to the process cwd or absolute).
# NOTE: local disk is ephemeral on containerised/serverless hosts — S-18 will
# replace this with an object-store backend via the StorageService abstraction.
UPLOAD_DIR=./uploads
# Maximum size of a single uploaded file, in bytes (default 5 MiB).
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
# Maximum number of files accepted in a single multipart request.
UPLOAD_MAX_FILES_PER_REQUEST=10
